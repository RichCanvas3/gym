OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# Use hosted LangGraph deployment for chat UI
NEXT_PUBLIC_USE_LANGGRAPH=0

# Next.js server -> LangSmith Deployment (keep these server-side only)
LANGGRAPH_DEPLOYMENT_URL=https://your-deployment-url
LANGGRAPH_ASSISTANT_ID=gym
LANGSMITH_API_KEY=lsv2_...

# Optional: MCP tool servers (used by the hosted agent)
#
# Provide a JSON object mapping serverName -> connection config.
# For Streamable HTTP, point to the server's `/mcp` endpoint.
#
# MCP_SERVERS_JSON={"calendar":{"transport":"streamable_http","url":"https://calendar.example.com/mcp","headers":{"Authorization":"Bearer ${CALENDAR_MCP_TOKEN}"}}}
MCP_SERVERS_JSON=
MCP_TOOL_NAME_PREFIX=1
MCP_TOOL_ALLOWLIST=
MCP_TOOL_DENYLIST=
MCP_STREAMABLE_HTTP_TIMEOUT_SECONDS=
MCP_STREAMABLE_HTTP_SSE_READ_TIMEOUT_SECONDS=

# Knowledge base indexing cache (includes MCP-synced content)
KB_INDEX_TTL_SECONDS=300

# Example: use the included SendGrid MCP server (apps/sendgrid-mcp)
# MCP_SERVERS_JSON={"sendgrid":{"transport":"streamable_http","url":"https://<your-worker>.workers.dev/mcp","headers":{"x-api-key":"${SENDGRID_MCP_API_KEY}"}}}
SENDGRID_MCP_API_KEY=

# Example: use the included Weather MCP server (apps/weather-mcp)
# MCP_SERVERS_JSON={"weather":{"transport":"streamable_http","url":"https://<your-worker>.workers.dev/mcp","headers":{"x-api-key":"${WEATHER_MCP_API_KEY}"}}}
WEATHER_MCP_API_KEY=

# Example: use the included Scheduling MCP server (apps/scheduling-mcp, Cloudflare Workers + D1)
# MCP_SERVERS_JSON={"scheduling":{"transport":"streamable_http","url":"https://<your-worker>.workers.dev/mcp","headers":{"x-api-key":"${SCHEDULING_MCP_API_KEY}"}}}
SCHEDULING_MCP_API_KEY=

# Example: use the included Gym Core MCP server (apps/gym-core-mcp, Cloudflare Workers + D1)
# MCP_SERVERS_JSON={"core":{"transport":"streamable_http","url":"https://<your-core-worker>.workers.dev/mcp","headers":{"x-api-key":"${GYM_CORE_MCP_API_KEY}"}}}
GYM_CORE_MCP_API_KEY=

# Example: use the included Content MCP server (apps/content-mcp, Cloudflare Workers + D1)
# MCP_SERVERS_JSON={"content":{"transport":"streamable_http","url":"https://<your-content-worker>.workers.dev/mcp","headers":{"x-api-key":"${CONTENT_MCP_API_KEY}"}}}
CONTENT_MCP_API_KEY=

# Example: use the included Google Calendar MCP server (apps/googlecalendar-mcp, Cloudflare Workers + D1)
# MCP_SERVERS_JSON={"googlecalendar":{"transport":"streamable_http","url":"https://<your-googlecal-worker>.workers.dev/mcp","headers":{"x-api-key":"${GOOGLECAL_MCP_API_KEY}"}}}
GOOGLECAL_MCP_API_KEY=
